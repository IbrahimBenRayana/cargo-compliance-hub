generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organizations ─────────────────────────────────────────
model Organization {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @db.VarChar(255)
  slug                String?  @unique @db.VarChar(100) // URL-friendly org identifier
  iorNumber           String?  @map("ior_number") @db.VarChar(100)
  einNumber           String?  @map("ein_number") @db.VarChar(20) // Encrypted
  address             Json?
  phone               String?  @db.VarChar(30)
  website             String?  @db.VarChar(255)
  logoUrl             String?  @map("logo_url") @db.VarChar(500)
  ccApiKeyEnc         String?  @map("cc_api_key_enc") // Encrypted CustomsCity API key
  ccEnvironment       String   @default("sandbox") @map("cc_environment") @db.VarChar(20)
  maxUsers            Int      @default(10) @map("max_users") // Seat limit
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  users           User[]
  filings         Filing[]
  submissionLogs  SubmissionLog[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  filingTemplates FilingTemplate[]
  invitations     OrgInvitation[]
  subscription    Subscription?
  shipmentCharges ShipmentCharge[]
  manifestQueries ManifestQuery[]
  abiDocuments    AbiDocument[]
  trackedShipments TrackedShipment[]
  apiKeys         ApiKey[]
  webhookEndpoints WebhookEndpoint[]

  @@map("organizations")
}

// ─── Users ─────────────────────────────────────────────────
model User {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  email          String    @unique @db.VarChar(255)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  firstName      String?   @map("first_name") @db.VarChar(100)
  lastName       String?   @map("last_name") @db.VarChar(100)
  role           String    @default("operator") @db.VarChar(20)
  // Platform-level staff (MyCargoLens), distinct from the org-scoped role.
  // Grants access to the /admin area that provisions client organizations.
  isPlatformAdmin Boolean  @default(false) @map("is_platform_admin")
  isActive       Boolean   @default(true) @map("is_active")
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastLoginAt    DateTime? @map("last_login_at") @db.Timestamptz()
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until") @db.Timestamptz()
  refreshToken   String?   @map("refresh_token")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization           Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  filings                Filing[]                 @relation("FilingCreator")
  statusChanges          FilingStatusHistory[]    @relation("StatusChanger")
  submissionLogs         SubmissionLog[]
  notifications          Notification[]
  notificationPreferences NotificationPreference[]
  auditLogs              AuditLog[]
  filingTemplates        FilingTemplate[]
  invitations            OrgInvitation[]          @relation("InvitationCreator")
  uploadedDocs           FilingDocument[]         @relation("DocumentUploader")
  manifestQueries        ManifestQuery[]
  abiDocuments           AbiDocument[]
  emailVerificationTokens EmailVerificationToken[]
  passwordSetupTokens    PasswordSetupToken[]
  trackedShipments       TrackedShipment[]
  apiKeys                ApiKey[]                 @relation("ApiKeyCreator")

  @@index([orgId])
  @@index([email])
  @@map("users")
}

// ─── API Keys (public API) ─────────────────────────────────
// Customer-issued credentials for the public /api/public/v1 surface (brokers,
// 3PLs, ERP integrations). The full key (mcl_live_…) is shown ONCE at creation
// and stored only as a SHA-256 hash; `prefix` is a non-secret display fragment.
// `scopes` gate what the key can do (e.g. filings:read, filings:write,
// entries:read, entries:write). Requests run under the key's org + tier
// capabilities, exactly like the app UI.
model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String    @db.VarChar(120)
  prefix      String    @db.VarChar(24) // non-secret, e.g. "mcl_live_a1b2"
  keyHash     String    @unique @map("key_hash") @db.VarChar(255) // sha256(full key)
  scopes      String[]
  createdById String    @map("created_by") @db.Uuid
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@index([orgId])
  @@map("api_keys")
}

// ─── Webhook Endpoints ─────────────────────────────────────
// Org-registered callback URLs for the public API. On a filing/entry status
// change we POST a JSON event signed with HMAC-SHA256 (header X-MCL-Signature:
// sha256=…) so integrators get push instead of polling. Best-effort delivery
// with a couple of retries; the last delivery outcome is recorded for debugging.
// The signing secret is stored as-is because the server must re-sign every
// payload with it (a hash would not allow that); it is shown in full only on
// create / rotate and masked elsewhere.
model WebhookEndpoint {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  url            String    @db.VarChar(2048)
  secret         String    @db.VarChar(255) // HMAC signing secret (whsec_…)
  secretPrefix   String    @map("secret_prefix") @db.VarChar(24) // non-secret hint, e.g. "whsec_a1b2"
  events         String[]  // subscribed event types; empty array = all events
  active         Boolean   @default(true)
  description    String?   @db.VarChar(200)
  createdById    String?   @map("created_by") @db.Uuid
  lastStatus     Int?      @map("last_status")
  lastError      String?   @map("last_error") @db.VarChar(500)
  lastDeliveryAt DateTime? @map("last_delivery_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("webhook_endpoints")
}

// ─── Password Setup Tokens ─────────────────────────────────
// Single-use, hashed link tokens emailed to a newly provisioned client owner
// (sales-led onboarding) so they can set their first password. Also doubles as
// a password-reset primitive. Unlike the 6-digit email codes these are long
// random tokens delivered in a link, so a longer TTL is acceptable.
//
// Lifecycle: provision user (no usable password) → issue token (e.g. 7-day TTL)
//   → user opens /set-password?token= → POST sets passwordHash, marks the user
//   emailVerified, and stamps consumedAt. Verified by SHA-256 hash lookup.
model PasswordSetupToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, createdAt])
  @@map("password_setup_tokens")
}

// ─── Email Verification Tokens ─────────────────────────────
// 6-digit codes emailed to the user. Stored as bcrypt hash since the
// numeric search space is small (1M); rate-limiting + 15-min expiry +
// 5-attempt cap is what actually keeps brute force off, but hashing is
// cheap defense in depth.
//
// Lifecycle:
//   request  → invalidate prior unconsumed → insert new token (15-min TTL)
//   confirm  → bcrypt.compare against most-recent active token → on match,
//              set User.emailVerified=true and mark consumedAt
//   resend   → 60s cooldown since lastIssuedAt; otherwise same as request
//
// We deliberately do NOT include the recipient email in the token — it
// belongs to one user, and that user's email is mutable. The userId FK
// is what binds the token to the right person.
model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  codeHash   String    @map("code_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  attempts   Int       @default(0)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Drainer/lookup index — we always want "most recent unconsumed token
  // for this user" which is (userId, consumedAt, createdAt DESC).
  @@index([userId, consumedAt, createdAt])
  @@map("email_verification_tokens")
}

// ─── ISF Filings ───────────────────────────────────────────
model Filing {
  id               String  @id @default(uuid()) @db.Uuid
  orgId            String  @map("org_id") @db.Uuid
  createdById      String  @map("created_by") @db.Uuid
  filingType       String  @map("filing_type") @db.VarChar(10) // ISF-10 | ISF-5
  status           String  @default("draft") @db.VarChar(30)
  ccFilingId       String? @map("cc_filing_id") @db.VarChar(100)
  cbpTransactionId String? @map("cbp_transaction_id") @db.VarChar(100)

  // Importer of Record
  importerName   String? @map("importer_name") @db.VarChar(255)
  importerNumber String? @map("importer_number") @db.VarChar(100)

  // Consignee
  consigneeName    String? @map("consignee_name") @db.VarChar(255)
  consigneeNumber  String? @map("consignee_number") @db.VarChar(100)
  consigneeAddress Json?   @map("consignee_address")

  // Parties (JSONB for flexibility)
  manufacturer              Json? // { name, address: { street, city, state, zip, country } }
  seller                    Json?
  buyer                     Json?
  shipToParty               Json? @map("ship_to_party")
  containerStuffingLocation Json? @map("container_stuffing_location")
  consolidator              Json?

  // Consolidation grouping (one Master BOL + multiple House BOLs).
  // ISF goes to CBP at the house-bill level — N HBLs under one MBL =
  // N filings that share this id. Null for single-HBL filings.
  consolidationId String? @map("consolidation_id") @db.Uuid

  // Shipment Details
  masterBol             String?   @map("master_bol") @db.VarChar(100)
  houseBol              String?   @map("house_bol") @db.VarChar(100)
  scacCode              String?   @map("scac_code") @db.VarChar(10)
  vesselName            String?   @map("vessel_name") @db.VarChar(255)
  voyageNumber          String?   @map("voyage_number") @db.VarChar(100)
  foreignPortOfUnlading String?   @map("foreign_port_of_unlading") @db.VarChar(10)
  placeOfDelivery       String?   @map("place_of_delivery") @db.VarChar(10)
  estimatedDeparture    DateTime? @map("estimated_departure") @db.Timestamptz()
  estimatedArrival      DateTime? @map("estimated_arrival") @db.Timestamptz()
  filingDeadline        DateTime? @map("filing_deadline") @db.Timestamptz()

  // Bond Info
  bondType       String? @map("bond_type") @db.VarChar(50)
  bondSuretyCode String? @map("bond_surety_code") @db.VarChar(10)

  // ISF-5 specific data (JSONB — booking party, ISF filer, etc.)
  isf5Data Json? @map("isf5_data")

  // Commodities & Containers (JSONB arrays)
  commodities Json @default("[]")
  containers  Json @default("[]")

  // Status timestamps
  submittedAt     DateTime? @map("submitted_at") @db.Timestamptz()
  acceptedAt      DateTime? @map("accepted_at") @db.Timestamptz()
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz()
  rejectionReason String?   @map("rejection_reason")
  amendedAt       DateTime? @map("amended_at") @db.Timestamptz()
  cancelledAt     DateTime? @map("cancelled_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization    Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy       User                  @relation("FilingCreator", fields: [createdById], references: [id])
  statusHistory   FilingStatusHistory[]
  scoreSnapshots  FilingScoreSnapshot[]
  submissionLogs  SubmissionLog[]
  notifications   Notification[]
  documents       FilingDocument[]
  manifestQueries ManifestQuery[]
  abiDocuments    AbiDocument[]
  trackedShipments TrackedShipment[]
  shipmentCharge  ShipmentCharge?

  @@index([orgId])
  @@index([status])
  @@index([createdById])
  @@index([filingDeadline])
  @@index([masterBol])
  @@index([consolidationId])
  @@map("filings")
}

// ─── Filing Status History ─────────────────────────────────
model FilingStatusHistory {
  id          String   @id @default(uuid()) @db.Uuid
  filingId    String   @map("filing_id") @db.Uuid
  status      String   @db.VarChar(30)
  message     String?
  ccResponse  Json?    @map("cc_response")
  changedById String?  @map("changed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  filing    Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)
  changedBy User?  @relation("StatusChanger", fields: [changedById], references: [id])

  @@index([filingId])
  @@map("filing_status_history")
}

// ─── Filing Score Snapshots ────────────────────────────────
// Captures the compliance score at every scoring event (creation,
// submission, rejection, acceptance, amendment, manual recompute) so
// the per-filing score-history endpoint can show validation-driven
// trajectories instead of flat status-band approximations.
model FilingScoreSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  filingId       String   @map("filing_id") @db.Uuid
  score          Int
  status         String   @db.VarChar(30)
  criticalCount  Int      @default(0) @map("critical_count")
  warningCount   Int      @default(0) @map("warning_count")
  infoCount      Int      @default(0) @map("info_count")
  triggerEvent   String   @map("trigger_event") @db.VarChar(40)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  filing Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)

  @@index([filingId, createdAt])
  @@map("filing_score_snapshots")
}

// ─── ADD/CVD Orders ────────────────────────────────────────
// Anti-Dumping / Countervailing Duty orders maintained by Commerce.
// Originally a JSON seed bundled with the server; moved to DB so the
// list can be refreshed by the Federal Register sync cron without
// requiring a redeploy. status='active' is the live list users see;
// 'pending' = discovered by sync, awaiting admin review; 'dismissed'
// = manually rejected.
model AddCvdOrder {
  id           String    @id @default(uuid()) @db.Uuid
  case         String    @db.VarChar(50)
  type         String    @db.VarChar(10) // AD | CVD | ADCVD
  country      String    @db.VarChar(10) // ISO-2
  product      String    @db.Text
  htsPrefixes  String[]  @map("hts_prefixes") @db.Text
  note         String?   @db.Text
  status       String    @default("active") @db.VarChar(20)
  source       String    @default("manual") @db.VarChar(40)
  sourceUrl    String?   @map("source_url") @db.Text
  sourceDate   DateTime? @map("source_date") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status])
  @@index([country])
  @@map("add_cvd_orders")
}

// ─── Submission Logs (API call audit trail) ────────────────
model SubmissionLog {
  id             String   @id @default(uuid()) @db.Uuid
  orgId          String   @map("org_id") @db.Uuid
  filingId       String?  @map("filing_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  correlationId  String?  @map("correlation_id") @db.VarChar(100)
  method         String   @db.VarChar(10)
  url            String
  requestPayload Json?    @map("request_payload")
  responseStatus Int?     @map("response_status")
  responseBody   Json?    @map("response_body")
  latencyMs      Int?     @map("latency_ms")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  filing       Filing?      @relation(fields: [filingId], references: [id], onDelete: SetNull)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([filingId])
  @@index([orgId])
  @@map("submission_logs")
}

// ─── Notifications ─────────────────────────────────────────
// Severity drives UI surface (toast escalation, severity rail color) and
// — once the dispatcher lands — email subject prefixing and retention.
enum NotificationSeverity {
  info
  warning
  critical

  @@map("notification_severity")
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @map("user_id") @db.Uuid
  orgId         String               @map("org_id") @db.Uuid
  filingId      String?              @map("filing_id") @db.Uuid
  abiDocumentId String?              @map("abi_document_id") @db.Uuid
  type          String               @db.VarChar(50)
  severity      NotificationSeverity @default(info)
  title         String               @db.VarChar(255)
  message       String?
  // Deep-link target the bell click should navigate to (eg. /shipments/:id).
  linkUrl       String?              @map("link_url") @db.VarChar(500)
  // Structured event payload (BOL number, deadline timestamp, CBP txn id, etc.).
  // Lets the UI render rich notification content without parsing title/message.
  metadata      Json?
  isRead        Boolean              @default(false) @map("is_read")
  readAt        DateTime?            @map("read_at") @db.Timestamptz()
  // Deduplication key for background-job alerts (e.g. "filingId_72h").
  // Globally unique so the same alert is never sent twice across restarts.
  dedupeKey     String?              @unique @map("dedupe_key") @db.VarChar(255)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz()

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  filing       Filing?                @relation(fields: [filingId], references: [id], onDelete: SetNull)
  abiDocument  AbiDocument?           @relation(fields: [abiDocumentId], references: [id], onDelete: SetNull)
  deliveries   NotificationDelivery[]

  @@index([userId])
  @@index([userId, isRead])
  // Powers the bell feed: paginate-by-date, filter unread.
  @@index([userId, createdAt(sort: Desc)])
  // Powers the Critical tab: only critical for this user.
  @@index([userId, severity, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Notification Delivery (Phase 6) ───────────────────────
// One row per (notification, channel) pair the system intends to deliver.
// In-app delivery is implicit — notifications already exist as Notification
// rows. This table is for out-of-band channels: email today, push later.
//
// Lifecycle:
//   queued  → worker picks up
//   sent    → terminal success
//   failed  → terminal failure (after `attempts` exhausted)
//   bounced → terminal failure reported by the email provider webhook
//
// Backoff: a failed attempt sets nextAttemptAt = now() + (2 ^ attempts)
// minutes, capped. The worker only picks rows where nextAttemptAt <= now().
model NotificationDelivery {
  id             String    @id @default(uuid()) @db.Uuid
  notificationId String    @map("notification_id") @db.Uuid
  channel        String    @db.VarChar(20)         // 'email' (and 'push' later)
  recipient      String    @db.VarChar(255)
  status         String    @default("queued") @db.VarChar(20)
  attempts       Int       @default(0)
  lastError      String?   @map("last_error")
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at") @db.Timestamptz()
  sentAt         DateTime? @map("sent_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  // Worker drain index. Prefix order matches the WHERE clause.
  @@index([status, nextAttemptAt])
  @@index([notificationId])
  // Defense-in-depth: a single (notification, recipient, channel) tuple must
  // never appear twice. The dispatcher dedupes via Notification.dedupeKey,
  // but if that ever fails (or a caller forgets to pass one), this constraint
  // stops a duplicate email at the DB layer. Paired with `skipDuplicates`
  // in enqueueEmailDeliveries.
  @@unique([notificationId, recipient, channel])
  @@map("notification_deliveries")
}

// ─── Notification Preferences ──────────────────────────────
// Per-user, per-kind opt-out. Defaults are opt-in (true) so new users
// receive everything until they actively turn channels off. Missing rows
// behave identically to {inApp: true, email: true} — saves us from
// having to seed prefs for every user × kind cross product.
model NotificationPreference {
  userId    String   @map("user_id") @db.Uuid
  kind      String   @db.VarChar(50)
  inApp     Boolean  @default(true) @map("in_app")
  email     Boolean  @default(true)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, kind])
  @@map("notification_preferences")
}

// ─── Audit Log (immutable) ─────────────────────────────────
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String?  @map("org_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  organization Organization? @relation(fields: [orgId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─── Filing Templates ──────────────────────────────────────
model FilingTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  createdById  String   @map("created_by") @db.Uuid
  name         String   @db.VarChar(255)
  filingType   String   @map("filing_type") @db.VarChar(10)
  templateData Json     @map("template_data")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@map("filing_templates")
}

// ─── Organisation Invitations ──────────────────────────────
model OrgInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  invitedById String    @map("invited_by") @db.Uuid
  email       String    @db.VarChar(255)
  role        String    @default("operator") @db.VarChar(20) // owner | admin | operator | viewer
  token       String    @unique @db.VarChar(100) // invite link token
  status      String    @default("pending") @db.VarChar(20) // pending | accepted | expired | revoked
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz()
  acceptedAt  DateTime? @map("accepted_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationCreator", fields: [invitedById], references: [id])

  @@index([orgId])
  @@index([email])
  @@index([token])
  @@map("org_invitations")
}

// ─── Filing Documents (file attachments) ───────────────────
model FilingDocument {
  id            String   @id @default(uuid()) @db.Uuid
  filingId      String   @map("filing_id") @db.Uuid
  uploadedById  String   @map("uploaded_by") @db.Uuid
  fileName      String   @map("file_name") @db.VarChar(255)
  fileType      String   @map("file_type") @db.VarChar(100) // MIME type
  fileSizeBytes Int      @map("file_size_bytes")
  storagePath   String   @map("storage_path") @db.VarChar(500) // Local path or S3 key
  documentType  String   @map("document_type") @db.VarChar(50) // bol, commercial_invoice, packing_list, other
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  filing     Filing @relation(fields: [filingId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([filingId])
  @@map("filing_documents")
}

// ─── Billing ─────────────────────────────────────────────

// Plan: a subscription tier (e.g., Grower Monthly, Scale Annual).
// Seeded from DB seed script; each plan maps to a Stripe Price via stripePriceId.
// Plan = a per-filing pricing tier. There is no monthly fee; `perFilingCents`
// is the metered Stripe Price unit_amount charged per billed shipment, and
// `capabilities` lists the product surfaces the tier unlocks. Source of truth
// for the values: server/src/config/plans.ts.
model Plan {
  id              String   @id // "isf" | "entry" | "full" | "enterprise"
  name            String // "ISF Filing"
  description     String?
  stripePriceId   String?  @unique @map("stripe_price_id") // metered Price; null until bootstrapped
  stripeProductId String?  @map("stripe_product_id")
  perFilingCents  Int      @map("per_filing_cents") // 4500 | 18000 | 28000 | 0 (enterprise/custom)
  currency        String   @default("usd") @db.VarChar(3)
  capabilities    String[] // unlocked capability keys (see CAPABILITIES)
  features        String[] // marketing bullet keys for the pricing UI
  isActive        Boolean  @default(true) @map("is_active")
  isPublic        Boolean  @default(true) @map("is_public") // show in pricing UI
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  subscriptions  Subscription[]
  shipmentCharges ShipmentCharge[]

  @@map("plans")
}

// Subscription: one per organization, tracks current Stripe subscription + plan.
model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  orgId                String    @unique @map("org_id") @db.Uuid
  planId               String    @map("plan_id")
  stripeCustomerId     String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  // Card-on-file billing (no Stripe subscription). The org keeps a default
  // payment method; each accepted shipment is charged immediately via a
  // PaymentIntent. status values:
  //   "card_on_file" — tier selected + a usable card saved (can file)
  //   "incomplete"   — tier selected but no card yet (cannot file paid tiers)
  //   "delinquent"   — a per-shipment charge failed; filing blocked until settled
  //   "active"       — legacy (pre-migration metered subscription); treated as card_on_file
  status               String    @default("incomplete") @db.VarChar(30)
  // Default payment method on file (Stripe pm_… id) + display summary.
  defaultPaymentMethodId String? @map("default_payment_method_id")
  cardBrand            String?   @map("card_brand") @db.VarChar(20)
  cardLast4            String?   @map("card_last4") @db.VarChar(4)
  cardExpMonth         Int?      @map("card_exp_month")
  cardExpYear          Int?      @map("card_exp_year")
  currentPeriodStart   DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz()
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime? @map("canceled_at") @db.Timestamptz()
  trialEnd             DateTime? @map("trial_end") @db.Timestamptz()
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([status])
  @@map("subscriptions")
}

// ShipmentCharge: the per-filing billing ledger. One row per billed shipment.
// The shipment is anchored on EITHER the ISF Filing (when present) OR a
// standalone ABI Entry — exactly one of filingId / abiDocumentId is set. An ABI
// Entry that is linked to an ISF Filing anchors on that filingId, so the ISF
// submit and the Entry send resolve to the SAME charge (no double-billing). The
// unique constraint on each anchor guarantees "one charge per shipment".
// `amountCents` locks the tier rate at first-bill time so a later tier change
// doesn't retro-price the shipment. Each row maps to one Stripe metered event;
// `status` tracks whether that event was reported.
model ShipmentCharge {
  id                 String   @id @default(uuid()) @db.Uuid
  orgId              String   @map("org_id") @db.Uuid
  filingId           String?  @unique @map("filing_id") @db.Uuid
  abiDocumentId      String?  @unique @map("abi_document_id") @db.Uuid
  planId             String   @map("plan_id") // tier at bill time
  amountCents        Int      @map("amount_cents") // locked per-filing rate
  stripeCustomerId   String?  @map("stripe_customer_id")
  stripeMeterEventId String?  @map("stripe_meter_event_id") // legacy (metered model)
  stripePaymentIntentId String? @map("stripe_payment_intent_id") // immediate-charge model
  // Immediate-charge model: pending → paid (PaymentIntent succeeded) | failed
  //   (declined/error, retry later) | requires_action (3DS — needs the customer) |
  //   skipped (no charge, e.g. $0 enterprise tier).
  status             String   @default("pending") @db.VarChar(20)
  billedAt           DateTime @default(now()) @map("billed_at") @db.Timestamptz()
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  filing       Filing?      @relation(fields: [filingId], references: [id], onDelete: Cascade)
  abiDocument  AbiDocument? @relation(fields: [abiDocumentId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([orgId, billedAt])
  @@index([status])
  @@map("shipment_charges")
}

// ─── Manifest Queries ─────────────────────────────────────
model ManifestQuery {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  bolNumber    String    @map("bol_number") @db.VarChar(100)
  bolType      String    @default("BOLNUMBER") @map("bol_type") @db.VarChar(20)
  ccRequestId  String?   @map("cc_request_id") @db.VarChar(100)
  status       String    @default("pending") @db.VarChar(20)
  response     Json?
  errorMessage String?   @map("error_message")
  pollAttempts Int       @default(0) @map("poll_attempts")
  filingId     String?   @map("filing_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt  DateTime? @map("completed_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  filing       Filing?       @relation(fields: [filingId], references: [id], onDelete: SetNull)
  abiDocuments AbiDocument[]

  @@index([orgId])
  @@index([bolNumber])
  @@index([orgId, createdAt])
  @@map("manifest_queries")
}

// ─── ABI Documents (CBP Entry Summary 7501 + Cargo Release 3461) ──
model AbiDocument {
  id     String @id @default(uuid()) @db.Uuid
  orgId  String @map("org_id") @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Local lifecycle status: DRAFT | SENDING | SENT | ACCEPTED | REJECTED | CANCELLED
  status String @default("DRAFT") @db.VarChar(20)

  // CC-assigned sub-statuses returned from /api/abi/documents
  entrySummaryStatus String? @map("entry_summary_status") @db.VarChar(20)
  cargoReleaseStatus String? @map("cargo_release_status") @db.VarChar(20)

  // Entry identifiers
  entryType       String  @map("entry_type") @db.VarChar(2) // 01 | 11
  modeOfTransport String  @map("mode_of_transport") @db.VarChar(2) // 40 = vessel, 41 = air
  entryNumber     String? @unique @map("entry_number") @db.VarChar(50)
  ccDocumentId    String? @map("cc_document_id") @db.VarChar(100)

  // Shipment denorm (for list search / filter)
  mbolNumber String? @map("mbol_number") @db.VarChar(100)
  hbolNumber String? @map("hbol_number") @db.VarChar(100)

  // Parties denorm
  iorNumber     String? @map("ior_number") @db.VarChar(100)
  iorName       String? @map("ior_name") @db.VarChar(255)
  consigneeName String? @map("consignee_name") @db.VarChar(255)

  // Ports & dates denorm (YYYYMMDD strings in UI; mapped to integers at send time)
  portOfEntry        String? @map("port_of_entry") @db.VarChar(10)
  destinationStateUS String? @map("destination_state_us") @db.VarChar(2)
  entryDate          String? @map("entry_date") @db.VarChar(8)
  importDate         String? @map("import_date") @db.VarChar(8)
  arrivalDate        String? @map("arrival_date") @db.VarChar(8)

  // Full CC-ready payload (the wizard-built document body)
  payload Json @default("{}")

  // Send lifecycle tracking
  sentAt       DateTime? @map("sent_at") @db.Timestamptz()
  respondedAt  DateTime? @map("responded_at") @db.Timestamptz()
  lastError    String?   @map("last_error")
  pollAttempts Int       @default(0) @map("poll_attempts")

  // Optional links
  filingId        String? @map("filing_id") @db.Uuid
  manifestQueryId String? @map("manifest_query_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id])
  filing         Filing?         @relation(fields: [filingId], references: [id], onDelete: SetNull)
  manifestQuery  ManifestQuery?  @relation(fields: [manifestQueryId], references: [id], onDelete: SetNull)
  notifications  Notification[]
  shipmentCharge ShipmentCharge?

  @@index([orgId, status])
  @@index([mbolNumber])
  @@index([entryNumber])
  @@index([orgId, createdAt])
  @@map("abi_documents")
}

// ─── Container Tracking (Terminal 49) ─────────────────────
// Persists a tracking request against the Terminal 49 API + a cached
// snapshot of the resolved shipment (so list views don't have to fan out
// to T49). The snapshot is refreshed on demand (manual /refresh) and —
// in Phase 2 — by webhook ingestion.
//
//   status lifecycle:
//     pending           → POST /tracking_requests accepted, T49 still
//                         fetching from the carrier
//     tracking          → tracking_request.succeeded; shipment + containers
//                         resolved and cached in shipmentSnapshot
//     failed            → tracking_request.failed (see failedReason)
//     stopped           → line_tracking_stopped_at populated by T49
model TrackedShipment {
  id                   String  @id @default(uuid()) @db.Uuid
  orgId                String  @map("org_id") @db.Uuid
  createdById          String  @map("created_by") @db.Uuid
  filingId             String? @map("filing_id") @db.Uuid

  // Terminal 49 identifiers
  t49TrackingRequestId String? @map("t49_tracking_request_id") @db.VarChar(100)
  t49ShipmentId        String? @map("t49_shipment_id") @db.VarChar(100)

  // Request inputs
  requestType   String  @map("request_type") @db.VarChar(20)
  requestNumber String  @map("request_number") @db.VarChar(100)
  scac          String  @db.VarChar(10)

  // Lifecycle
  status       String  @default("pending") @db.VarChar(20)
  failedReason String? @map("failed_reason")

  // Cached snapshot fields (denormalized for list filters / sort)
  shippingLineName    String?   @map("shipping_line_name") @db.VarChar(255)
  portOfLadingName    String?   @map("port_of_lading_name") @db.VarChar(255)
  portOfDischargeName String?   @map("port_of_discharge_name") @db.VarChar(255)
  destinationName     String?   @map("destination_name") @db.VarChar(255)
  podVesselName       String?   @map("pod_vessel_name") @db.VarChar(255)
  polEtdAt            DateTime? @map("pol_etd_at") @db.Timestamptz()
  polAtdAt            DateTime? @map("pol_atd_at") @db.Timestamptz()
  podEtaAt            DateTime? @map("pod_eta_at") @db.Timestamptz()
  podAtaAt            DateTime? @map("pod_ata_at") @db.Timestamptz()
  destinationEtaAt    DateTime? @map("destination_eta_at") @db.Timestamptz()
  destinationAtaAt    DateTime? @map("destination_ata_at") @db.Timestamptz()
  hasHolds            Boolean   @default(false) @map("has_holds")
  earliestPickupLfd   DateTime? @map("earliest_pickup_lfd") @db.Timestamptz()

  // Full ShipmentSummary (JSON serialized) — drives the detail view.
  shipmentSnapshot Json? @map("shipment_snapshot")

  // Sync metadata
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz()
  syncError    String?   @map("sync_error")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])
  filing       Filing?      @relation(fields: [filingId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([filingId])
  @@unique([orgId, t49ShipmentId])
  @@map("tracked_shipments")
}

// ─── Stripe Webhook Events (idempotency ledger) ────────────
// Stripe retries on 5xx and occasionally after 2xx. We INSERT the event_id
// ON CONFLICT DO NOTHING at handler entry — a returning row means we've
// processed this event before and should bail. Without this, the same
// `customer.subscription.deleted` event runs our handler N times and
// clobbers `canceledAt` on every retry. processedAt is filled after the
// handler finishes so we can tell "received but never finished" apart from
// "fully handled".
model StripeWebhookEvent {
  eventId     String    @id @map("event_id")
  type        String
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz()
  processedAt DateTime? @map("processed_at") @db.Timestamptz()

  @@index([receivedAt(sort: Desc)])
  @@map("stripe_webhook_events")
}
