# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/mycargolens?schema=public"

# ── JWT Secrets ──────────────────────────────────────────
JWT_ACCESS_SECRET="CHANGE_ME_32_CHARS_MINIMUM"
JWT_REFRESH_SECRET="CHANGE_ME_32_CHARS_MINIMUM"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── MFA (TOTP secret encryption) ─────────────────────────
# AES-256-GCM key that encrypts users' TOTP secrets at rest. 32 bytes as
# 64 hex chars — generate with: openssl rand -hex 32
# Optional in development (a key is derived from JWT_ACCESS_SECRET), but
# REQUIRED in production. Rotating/losing it makes enrolled TOTP secrets
# undecryptable, forcing every user to re-enroll.
MFA_ENC_KEY=""

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:8080"

# ── CustomsCity API ──────────────────────────────────────
CC_API_BASE_URL="https://api-cert.customscity.com"
CC_API_TOKEN="your-sandbox-jwt-token"
CC_ENVIRONMENT="sandbox"

# ── Terminal 49 (Container Tracking) ──────────────────────
# https://terminal49.com/docs/api-docs/getting-started — Bearer token (no SCAC for vessel events).
# Optional: leave blank to disable the Container Tracking feature. /tracking/status
# reports "disabled" when unset, and the UI hides the page.
TERMINAL49_API_BASE_URL="https://api.terminal49.com/v2"
TERMINAL49_API_KEY=""

# ── Stripe (Billing) ──────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get this after creating the webhook endpoint in Dashboard:
# https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
