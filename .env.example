# ============================================================
# MyCargoLens — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# For Docker Compose: these are read automatically.
# For bare-metal: place in server/.env
# ============================================================

# ── Database ─────────────────────────────────────────────
# For Docker Compose: auto-configured via docker-compose.yml
# For bare-metal: your PostgreSQL connection string
DB_PASSWORD=change-me-strong-password-here

# ── JWT Secrets (REQUIRED — generate with: openssl rand -hex 32) ──
JWT_ACCESS_SECRET=change-me-generate-a-long-random-secret
JWT_REFRESH_SECRET=change-me-generate-another-long-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-domain.com

# ── Frontend API URL (set if API is on a different domain) ──
# Leave empty if frontend is served from the same origin as the API
VITE_API_URL=

# ── CustomsCity API ──────────────────────────────────────
CC_API_BASE_URL=https://api-cert.customscity.com
CC_API_TOKEN=your-customscity-api-token
CC_ENVIRONMENT=sandbox

# ── Email (Azure Communication Services SMTP) ───────────
EMAIL_HOST=smtp.azurecomm.net
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASS=your-smtp-password
EMAIL_FROM=DoNotReply@your-domain.com
EMAIL_FROM_NAME=MyCargoLens
